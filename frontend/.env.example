# Frontend environment variables (Vite). Copy to ".env.local" to override locally.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Backend base URL. Leave EMPTY to use same-origin "/api/..." paths — in dev the
# Vite proxy forwards these to FastAPI on :8000 (see vite.config.ts). Set this to
# point the UI at a backend on a DIFFERENT origin in production, e.g.:
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
